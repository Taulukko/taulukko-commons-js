{
  "name": "taulukko-commons",
  "version": "1.3.0",
  "description": "Taulukko Commons Library",
  "license": "MIT",
  "author": "Taulukko Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/taulukko/taulukko-js-commons"
  },
  "keywords": [
    "utilities",
    "strings",
    "dates",
    "logging",
    "di",
    "dependency-injection"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "lint": "tslint --exclude '**/*.temp.ts' --exclude '**/node_modules/**' -p . ",
    "tsfm": "tsfmt -r --no-tslint",
    "build": "rimraf ./dist && tsc -p tsconfig.json --sourceMap",
    "test": "clear && jest"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.11",
    "tslint": "^5.11.0",
    "tslint-eslint-rules-recommended": "^1.2.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "node-cache": "^5.1.2",
    "yargs-parser": "^22.0.0"
  }
}
